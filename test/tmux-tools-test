#!/usr/bin/env bash
case "$1" in
  display-message)
    target=""
    while (($#)); do
      if [[ "$1" == -t ]]; then
        target="$2"
        break
      fi
      shift
    done
    [[ "$target" != %999 ]] || exit 1
    pane="${target#%}"
    printf '%s:%%%s\n' "${TMUX_TOOLS_TEST_SERVER_PID:-101}" \
      "${pane:-${TMUX_TOOLS_TEST_PANE_ID:-1}}"
    ;;
  load-buffer | paste-buffer | delete-buffer)
    printf '%s\n' "$*" >>"$TMUX_TOOLS_TEST_TMUX_LOG"
    buffer_state="$TMUX_TOOLS_TEST_TMUX_LOG.buffer"
    if [[ "$1" == load-buffer ]]; then
      printf '%s\n' "$3" >"$buffer_state"
    fi
    if [[ "$1" == load-buffer && -n "${TMUX_TOOLS_TEST_LOAD_READY:-}" ]]; then
      cat "${!#}" >"$TMUX_TOOLS_TEST_LOADED_PAYLOAD"
      : >"$TMUX_TOOLS_TEST_LOAD_READY"
      for ((attempt = 0; attempt < 500; attempt++)); do
        [[ ! -e "$TMUX_TOOLS_TEST_LOAD_CONTINUE" ]] || break
        sleep 0.01
      done
      [[ -e "$TMUX_TOOLS_TEST_LOAD_CONTINUE" ]] || exit 98
    fi
    if [[ "$1" == load-buffer && -n "${TMUX_TOOLS_TEST_FAIL_LOAD:-}" ]]; then
      exit 1
    fi
    if [[ "$1" == paste-buffer && -n "${TMUX_TOOLS_TEST_FAIL_PASTE:-}" ]]; then
      exit 1
    fi
    if [[ "$1" == paste-buffer && -n "${TMUX_TOOLS_TEST_COMMIT_PASTE:-}" ]]; then
      rm -f "$buffer_state"
      if [[ -n "${TMUX_TOOLS_TEST_SIGNAL_PASTE:-}" ]]; then
        kill -TERM "$PPID"
      fi
      exit 42
    fi
    if [[ "$1" == paste-buffer && "$*" == *' -d'* ]]; then
      rm -f "$buffer_state"
    elif [[ "$1" == delete-buffer ]]; then
      rm -f "$buffer_state"
    fi
    ;;
  list-buffers)
    printf '%s\n' "$*" >>"$TMUX_TOOLS_TEST_TMUX_LOG"
    buffer_state="$TMUX_TOOLS_TEST_TMUX_LOG.buffer"
    [[ ! -e "$buffer_state" ]] || cat "$buffer_state"
    ;;
  *)
    printf 'unexpected tmux command: %s\n' "$*" >&2
    exit 99
    ;;
esac
MOCK
