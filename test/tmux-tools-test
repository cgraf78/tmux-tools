  : >"$retain_race_continue"
  kill "$retain_race_consumer" 2>/dev/null || :
  wait "$retain_race_consumer" 2>/dev/null || :
  retain_race_rc=98
fi
_assert_eq "failing clip consumer classifies the retain race as operational" \
  "1" "$retain_race_rc"
_assert_eq "failing clip consumer preserves producer B at the public path" \
  "retain-race payload B" "$(cat "$retain_race_file")"
retain_race_claim=$(printf '%s\n' "$clip_dir"/.retain-race-selection.consume.*/payload)
_assert_eq "failing clip consumer preserves claim A after public replacement" \
  "retain-race payload A" "$(cat "$retain_race_claim")"
_assert_eq "failing clip consumer keeps race claim directory private" \
  "700" "$(_mode "$(dirname "$retain_race_claim")")"
_assert_eq "failing clip consumer keeps race claim payload private" \
  "600" "$(_mode "$retain_race_claim")"
_assert_contains "failing clip consumer reports exact claim after public replacement" \
  "$retain_race_claim" "$(cat "$retain_race_output")"

empty_race_file="$clip_dir/empty-race-selection"
empty_race_ready="$clip_dir/empty-race.ready"
empty_race_continue="$clip_dir/empty-race.continue"
empty_race_bin=$(_tmpdir)
empty_real_mv=$(command -v mv)
empty_real_rm=$(command -v rm)
: >"$empty_race_file"
cat >"$empty_race_bin/mv" <<'MOCK'
#!/usr/bin/env bash
"$TMUX_TOOLS_TEST_REAL_MV" "$@"
destination="${!#}"
if [[ "$destination" == *.empty-race-selection.consume.* ]]; then
  : >"$TMUX_TOOLS_TEST_READY"
  for ((attempt = 0; attempt < 500; attempt++)); do
    [[ ! -e "$TMUX_TOOLS_TEST_CONTINUE" ]] || exit 0
    sleep 0.01
  done
  exit 98
fi
MOCK
cat >"$empty_race_bin/rm" <<'MOCK'
#!/usr/bin/env bash
target="${!#}"
if [[ "$target" == "$TMUX_TOOLS_TEST_SHARED_FILE" ]]; then
  : >"$TMUX_TOOLS_TEST_READY"
  for ((attempt = 0; attempt < 500; attempt++)); do
    [[ ! -e "$TMUX_TOOLS_TEST_CONTINUE" ]] || break
    sleep 0.01
  done
  [[ -e "$TMUX_TOOLS_TEST_CONTINUE" ]] || exit 98
fi
exec "$TMUX_TOOLS_TEST_REAL_RM" "$@"
MOCK
chmod +x "$empty_race_bin/mv" "$empty_race_bin/rm"
PATH="$empty_race_bin:$PATH" TMUX_TOOLS_TEST_REAL_MV="$empty_real_mv" \
  TMUX_TOOLS_TEST_REAL_RM="$empty_real_rm" \
  TMUX_TOOLS_TEST_SHARED_FILE="$empty_race_file" \
  TMUX_TOOLS_TEST_READY="$empty_race_ready" \
  TMUX_TOOLS_TEST_CONTINUE="$empty_race_continue" \
  tmux-clip-paste --file "$empty_race_file" >/dev/null 2>&1 &
empty_race_consumer=$!
if _wait_for_file "empty clip consumer pauses after claiming its payload" "$empty_race_ready"; then
  printf 'new nonempty payload\n' | tmux-clip-paste --file "$empty_race_file" --publish
  : >"$empty_race_continue"
  wait "$empty_race_consumer"
  empty_race_rc=$?
else
  : >"$empty_race_continue"
  kill "$empty_race_consumer" 2>/dev/null || :
  wait "$empty_race_consumer" 2>/dev/null || :
  empty_race_rc=98
fi
_assert_eq "empty clip consumer succeeds after a concurrent replacement" \
  "0" "$empty_race_rc"
_assert_eq "empty clip consumer leaves the newer nonempty payload" \
  "new nonempty payload" "$(cat "$empty_race_file" 2>/dev/null)"

barrier_dir=$(_tmpdir)
barrier_bin=$(_tmpdir)
barrier_a="$barrier_dir/a.payload"
barrier_b="$barrier_dir/b.payload"
printf 'payload A\n' >"$barrier_a"
printf 'payload B\n' >"$barrier_b"
cat >"$barrier_bin/tmux" <<'MOCK'
#!/usr/bin/env bash
set -u

_wait() {
  local path="$1" attempt
  for ((attempt = 0; attempt < 500; attempt++)); do
    [[ -e "$path" ]] && return 0
    sleep 0.01
  done
  exit 98
}

command="$1"
shift
case "$command" in
  display-message)
    if [[ "$TMUX_TOOLS_TEST_ROLE" == A ]]; then
      printf '303:%%1\n'
    else
      printf '303:%%2\n'
    fi
    ;;
  load-buffer)
    buffer="unnamed"
    file=""
    while (($#)); do
      case "$1" in
        -b) buffer="$2"; shift 2 ;;
        *) file="$1"; shift ;;
      esac
    done
    safe_buffer="${buffer//[^A-Za-z0-9_.%-]/_}"
    cp "$file" "$TMUX_TOOLS_TEST_BARRIER/buffer-$safe_buffer"
    if [[ "$TMUX_TOOLS_TEST_ROLE" == A ]]; then
      : >"$TMUX_TOOLS_TEST_BARRIER/a-loaded"
      _wait "$TMUX_TOOLS_TEST_BARRIER/b-loaded"
    else
      : >"$TMUX_TOOLS_TEST_BARRIER/b-loaded"
      _wait "$TMUX_TOOLS_TEST_BARRIER/a-pasted"
    fi
    ;;
  paste-buffer)
    buffer="unnamed"
    target=""
    delete=0
    while (($#)); do
      case "$1" in
        -b) buffer="$2"; shift 2 ;;
        -t) target="$2"; shift 2 ;;
        -d) delete=1; shift ;;
        *) shift ;;
      esac
    done
    safe_buffer="${buffer//[^A-Za-z0-9_.%-]/_}"
    cat "$TMUX_TOOLS_TEST_BARRIER/buffer-$safe_buffer" \
      >"$TMUX_TOOLS_TEST_BARRIER/pasted-$TMUX_TOOLS_TEST_ROLE"
    printf '%s\n' "$target" >"$TMUX_TOOLS_TEST_BARRIER/target-$TMUX_TOOLS_TEST_ROLE"
    if [[ "$TMUX_TOOLS_TEST_ROLE" == A ]]; then
      : >"$TMUX_TOOLS_TEST_BARRIER/a-pasted"
    fi
    if ((delete)); then
      rm -f "$TMUX_TOOLS_TEST_BARRIER/buffer-$safe_buffer"
    fi
    ;;
  delete-buffer)
    buffer=""
    while (($#)); do
      case "$1" in
        -b) buffer="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    safe_buffer="${buffer//[^A-Za-z0-9_.%-]/_}"
    rm -f "$TMUX_TOOLS_TEST_BARRIER/buffer-$safe_buffer"
    ;;
  *)
    exit 99
    ;;
esac
MOCK
chmod +x "$barrier_bin/tmux"
env -u TMUX_PANE PATH="$barrier_bin:$PATH" TMUX_TOOLS_TEST_BARRIER="$barrier_dir" \
  TMUX_TOOLS_TEST_ROLE=A tmux-clip-paste --file "$barrier_a" >/dev/null 2>&1 &
barrier_a_pid=$!
if _wait_for_file "clip race reaches the first completed load" "$barrier_dir/a-loaded"; then
  env -u TMUX_PANE PATH="$barrier_bin:$PATH" TMUX_TOOLS_TEST_BARRIER="$barrier_dir" \
    TMUX_TOOLS_TEST_ROLE=B tmux-clip-paste --file "$barrier_b" >/dev/null 2>&1 &
  barrier_b_pid=$!
  wait "$barrier_a_pid"
  barrier_a_rc=$?
  wait "$barrier_b_pid"
  barrier_b_rc=$?
else
  kill "$barrier_a_pid" 2>/dev/null || :
  wait "$barrier_a_pid" 2>/dev/null || :
  barrier_a_rc=98
  barrier_b_rc=98
fi
_assert_eq "clip race consumer A succeeds" "0" "$barrier_a_rc"
_assert_eq "clip race consumer B succeeds" "0" "$barrier_b_rc"
_assert_eq "clip race pastes A's own named buffer" \
  "payload A" "$(cat "$barrier_dir/pasted-A")"
_assert_eq "clip race pastes B's own named buffer" \
  "payload B" "$(cat "$barrier_dir/pasted-B")"
_assert_eq "clip race retains A's resolved target" \
  "%1" "$(cat "$barrier_dir/target-A")"
_assert_eq "clip race retains B's resolved target" \
  "%2" "$(cat "$barrier_dir/target-B")"
barrier_buffers=$(printf '%s\n' "$barrier_dir"/buffer-*)
_assert_eq "clip race deletes all named buffers" \
  "$barrier_dir/buffer-*" "$barrier_buffers"

if command -v tmux >/dev/null 2>&1; then
  real_tmux=$(command -v tmux)
  socket_dir=$(_tmpdir)
  socket="$socket_dir/tmux-tools.sock"
  tool_bin=$(_tmpdir)
  session_dir=$(_tmpdir)
  project_dir=$(_tmpdir)
  stale_dir=$(_tmpdir)

  cat >"$tool_bin/tmux" <<MOCK
#!/usr/bin/env bash
exec "$real_tmux" -S "$socket" "\$@"
MOCK
  chmod +x "$tool_bin/tmux"

  real_clip_dir=$(_tmpdir)
  real_clip_a="$real_clip_dir/a.payload"
  real_clip_b="$real_clip_dir/b.payload"
  real_output_a="$real_clip_dir/a.output"
  real_output_b="$real_clip_dir/b.output"
  printf 'real pane A\n' >"$real_clip_a"
  printf 'real pane B\n' >"$real_clip_b"
  "$real_tmux" -S "$socket" -f /dev/null new-session -d -s clip-target \
    "cat >'$real_output_a'"
  real_pane_a=$(
    "$real_tmux" -S "$socket" display-message -p -t clip-target '#{pane_id}'
  )
  real_pane_b=$(
    "$real_tmux" -S "$socket" split-window -d -P -F '#{pane_id}' -t clip-target \
      "cat >'$real_output_b'"
  )
  "$real_tmux" -S "$socket" run-shell -t "$real_pane_a" \
    "env -u TMUX_PANE PATH='$tool_bin:$ROOT/bin:$PATH' tmux-clip-paste --pane '$real_pane_a' --file '$real_clip_a'"
  "$real_tmux" -S "$socket" run-shell -t "$real_pane_b" \
    "env TMUX_PANE=%999 PATH='$tool_bin:$ROOT/bin:$PATH' tmux-clip-paste --pane '$real_pane_b' --file '$real_clip_b'"
  _wait_for_content "real tmux run-shell pastes with TMUX_PANE unset" \
    "$real_output_a" "real pane A"
  _wait_for_content "real tmux run-shell overrides stale TMUX_PANE" \
    "$real_output_b" "real pane B"
  "$real_tmux" -S "$socket" kill-session -t clip-target

  "$real_tmux" -S "$socket" -f /dev/null new-session -d -s tmux-tools-test -n dup \
    -c "$project_dir" 'sleep 60'
  "$real_tmux" -S "$socket" new-window -t tmux-tools-test -n dup \
    -c "$stale_dir" 'sleep 60'
  second_window=$("$real_tmux" -S "$socket" display-message -p -t tmux-tools-test '#{window_index}')
  "$real_tmux" -S "$socket" split-window -t "tmux-tools-test:$second_window" \
    -c "$project_dir" 'sleep 60'
  "$real_tmux" -S "$socket" new-window -t tmux-tools-test -n stale \
    -c "$stale_dir" 'sleep 60'
  "$real_tmux" -S "$socket" select-window -t "tmux-tools-test:$second_window"

  PATH="$tool_bin:$PATH" TMUX_TOOLS_SESSION_DIR="$session_dir" \
    tmux-save-session tmux-tools-test >/dev/null

  rm -rf "$stale_dir"
  "$real_tmux" -S "$socket" kill-session -t tmux-tools-test

  PATH="$tool_bin:$PATH" TMUX_TOOLS_SESSION_DIR="$session_dir" \
    tmux-restore-session --no-attach tmux-tools-test >/dev/null

  active_panes=$("$real_tmux" -S "$socket" list-panes -t tmux-tools-test | wc -l | tr -d ' ')
  _assert_eq "restore preserves active saved window" "2" "$active_panes"

  restored_indexes=()
  while IFS= read -r restored_index; do
    restored_indexes+=("$restored_index")
  done < <("$real_tmux" -S "$socket" list-windows -t tmux-tools-test -F '#{window_index}')
  first_index="${restored_indexes[0]}"
  second_index="${restored_indexes[1]}"
  third_index="${restored_indexes[2]}"
  first_panes=$("$real_tmux" -S "$socket" list-panes -t "tmux-tools-test:$first_index" | wc -l | tr -d ' ')
  second_panes=$("$real_tmux" -S "$socket" list-panes -t "tmux-tools-test:$second_index" | wc -l | tr -d ' ')
  _assert_eq "restore handles duplicate first window name" "1" "$first_panes"
  _assert_eq "restore handles duplicate second window name" "2" "$second_panes"

  restored_dir=$("$real_tmux" -S "$socket" display-message -p -t "tmux-tools-test:$third_index.0" '#{pane_current_path}')
  _assert_eq "restore falls back to HOME for missing cwd" "$HOME" "$restored_dir"

  "$real_tmux" -S "$socket" kill-server
else
  printf 'skip - tmux server integration checks (tmux not installed)\n'
fi

if ((_failures > 0)); then
  printf '%s failure(s)\n' "$_failures" >&2
  exit 1
fi

printf 'all tests passed\n'
