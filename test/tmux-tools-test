#!/usr/bin/env bash

set -uo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
PATH="$ROOT/bin:$PATH"
export NO_COLOR=1

# shellcheck source=lib/tmux-tools/session.sh
. "$ROOT/lib/tmux-tools/session.sh"

_failures=0
_temps=()

_tmpdir() {
  local dir
  dir=$(mktemp -d)
  _temps+=("$dir")
  printf '%s\n' "$dir"
}

_cleanup() {
  local dir
  for dir in "${_temps[@]}"; do
    rm -rf "$dir"
  done
}
trap _cleanup EXIT

_pass() {
  printf 'ok - %s\n' "$1"
}

_fail() {
  printf 'not ok - %s\n' "$1" >&2
  _failures=$((_failures + 1))
}

_assert_eq() {
  local name="$1"
  local expected="$2"
  local actual="$3"

  if [[ "$actual" == "$expected" ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected: %q\n' "$expected" >&2
    printf '  actual:   %q\n' "$actual" >&2
  fi
}

_assert_contains() {
  local name="$1"
  local needle="$2"
  local haystack="$3"

  if [[ "$haystack" == *"$needle"* ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected output to contain: %s\n' "$needle" >&2
    printf '  actual output:\n%s\n' "$haystack" >&2
  fi
}

_assert_symlink() {
  local name="$1"
  local path="$2"

  if [[ -L "$path" ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected symlink: %s\n' "$path" >&2
  fi
}

echo "=== tmux session tools ==="

test_home="$HOME"
helper_dir=$(_tmpdir)
mkdir -p "$helper_dir"
: >"$helper_dir/beta.sh"
: >"$helper_dir/alpha.sh"
helper_sessions=$(tmux_tools_saved_sessions "$helper_dir")
_assert_eq "session helper lists saved sessions sorted" "$(printf 'alpha\nbeta')" "$helper_sessions"
_assert_eq "session helper builds restore script path" \
  "$helper_dir/alpha.sh" "$(tmux_tools_session_file "$helper_dir" alpha)"
unset TMUX_TOOLS_SESSION_DIR
HOME="$helper_dir/home" XDG_DATA_HOME=''
tmux_tools_resolve_session_dir
helper_default="$REPLY"
_assert_eq "session helper default dir follows XDG data fallback" \
  "$helper_dir/home/.local/share/tmux/sessions" "$helper_default"
_assert_eq "session helper keeps the compatibility output API" \
  "$helper_default" "$(tmux_tools_default_session_dir)"
XDG_DATA_HOME="relative/data"
tmux_tools_resolve_session_dir
_assert_eq "session helper rejects relative XDG data roots" \
  "$helper_dir/home/.local/share/tmux/sessions" "$REPLY"
export XDG_DATA_HOME="$helper_dir/xdg"
unset HOME
tmux_tools_resolve_session_dir
_assert_eq "session helper accepts absolute XDG data roots without HOME" \
  "$helper_dir/xdg/tmux/sessions" "$REPLY"
helper_override="$helper_dir/custom"$'\n'
TMUX_TOOLS_SESSION_DIR="$helper_override"
tmux_tools_resolve_session_dir
_assert_eq "session helper preserves override trailing newlines" "$helper_override" "$REPLY"
export TMUX_TOOLS_SESSION_DIR=""
tmux_tools_resolve_session_dir
_assert_eq "session helper preserves an explicitly empty override" "" "$REPLY"
unset TMUX_TOOLS_SESSION_DIR XDG_DATA_HOME HOME
REPLY="stale"
if tmux_tools_resolve_session_dir; then
  _fail "session helper fails closed without XDG data or HOME"
else
  _pass "session helper fails closed without XDG data or HOME"
fi
_assert_eq "session helper clears stale output when roots are unavailable" "" "$REPLY"
export HOME="$test_home"

save_help=$(tmux-save-session --help 2>&1)
_assert_contains "tmux-save-session help documents --dir" "--dir DIR" "$save_help"
restore_help=$(tmux-restore-session --help 2>&1)
_assert_contains "tmux-restore-session help documents --no-attach" "--no-attach" "$restore_help"
clip_help=$(tmux-clip-paste --help 2>&1)
_assert_contains "tmux-clip-paste help documents --path" "--path" "$clip_help"

missing_root_output=$(env -u HOME -u XDG_DATA_HOME -u TMUX_TOOLS_SESSION_DIR \
  tmux-restore-session --list 2>&1)
missing_root_rc=$?
_assert_eq "restore reports a usage error when no default root exists" "2" "$missing_root_rc"
_assert_contains "restore explains the missing default root" \
  "HOME is not set and XDG_DATA_HOME is not absolute" "$missing_root_output"
explicit_no_home=$(_tmpdir)
env -u HOME -u XDG_DATA_HOME -u TMUX_TOOLS_SESSION_DIR \
  tmux-restore-session --dir "$explicit_no_home" --list >/dev/null
_assert_eq "restore explicit --dir works without default roots" "0" "$?"

list_dir=$(_tmpdir)
mkdir -p "$list_dir"
: >"$list_dir/beta.sh"
: >"$list_dir/alpha.sh"
result=$(tmux-restore-session --dir "$list_dir" --list)
expected="$(printf 'alpha\nbeta')"
_assert_eq "restore lists saved sessions sorted" "$expected" "$result"

single_dir=$(_tmpdir)
single_log=$(_tmpdir)/single.log
single_bin=$(_tmpdir)
mkdir -p "$single_dir"
cat >"$single_dir/solo.sh" <<'MOCK'
#!/usr/bin/env bash
printf 'solo\n' >"$TMUX_TOOLS_TEST_RESTORED"
MOCK
chmod +x "$single_dir/solo.sh"
cat >"$single_bin/tmux" <<'MOCK'
#!/usr/bin/env bash
case "$1" in
  has-session) exit 1 ;;
  *) printf 'unexpected tmux command: %s\n' "$*" >&2; exit 99 ;;
esac
MOCK
chmod +x "$single_bin/tmux"
result=$(
  PATH="$single_bin:$PATH" TMUX_TOOLS_TEST_RESTORED="$single_log" \
    tmux-restore-session --dir "$single_dir" --no-attach 2>&1
)
_assert_contains "restore picks only saved session directly" "restored: solo" "$result"
_assert_eq "restore runs picked session script" "solo" "$(cat "$single_log")"

install_prefix=$(_tmpdir)
PREFIX="$install_prefix" "$ROOT/install.sh" >/dev/null
_assert_symlink "install links save command" "$install_prefix/bin/tmux-save-session"
_assert_symlink "install links restore command" "$install_prefix/bin/tmux-restore-session"
_assert_symlink "install links save manpage" "$install_prefix/share/man/man1/tmux-save-session.1"
_assert_symlink "install links restore manpage" "$install_prefix/share/man/man1/tmux-restore-session.1"
_assert_symlink "install links clip manpage" "$install_prefix/share/man/man1/tmux-clip-paste.1"
installed_save_help=$("$install_prefix/bin/tmux-save-session" --help 2>&1)
_assert_contains "installed save command resolves helper library" \
  "tmux-save-session" "$installed_save_help"
installed_restore_list=$("$install_prefix/bin/tmux-restore-session" --dir "$single_dir" --list)
_assert_eq "installed restore command resolves helper library" "solo" "$installed_restore_list"

custom_install_prefix=$(_tmpdir)
custom_install_bin=$(_tmpdir)/custom-bin
custom_install_man=$(_tmpdir)/custom-man
PREFIX="$custom_install_prefix" BIN_DIR="$custom_install_bin" MAN_DIR="$custom_install_man" \
  "$ROOT/install.sh" >/dev/null
custom_save_help=$("$custom_install_bin/tmux-save-session" --help 2>&1)
_assert_contains "custom BIN_DIR save command resolves helper library" \
  "tmux-save-session" "$custom_save_help"
_assert_symlink "custom MAN_DIR receives save manpage" "$custom_install_man/tmux-save-session.1"

clip_dir=$(_tmpdir)
clip_file="$clip_dir/selection"
clip_bin=$(_tmpdir)
clip_log="$clip_dir/tmux.log"
cat >"$clip_bin/tmux" <<'MOCK'
#!/usr/bin/env bash
printf '%s\n' "$*" >>"$TMUX_TOOLS_TEST_TMUX_LOG"
MOCK
chmod +x "$clip_bin/tmux"

result=$(TMPDIR="$clip_dir" tmux-clip-paste --path)
_assert_eq "clip paste prints default per-user path" \
  "$clip_dir/.tmux-clip-paste-$(id -u)" "$result"

result=$(TMUX_TOOLS_CLIP_PASTE_FILE="$clip_file" tmux-clip-paste --path)
_assert_eq "clip paste path honors env override" "$clip_file" "$result"

printf 'picked text\n' >"$clip_file"
PATH="$clip_bin:$PATH" TMUX_TOOLS_TEST_TMUX_LOG="$clip_log" \
  tmux-clip-paste --file "$clip_file"
expected="$(printf 'load-buffer %s\npaste-buffer -p' "$clip_file")"
_assert_eq "clip paste loads and pastes selected file" "$expected" "$(cat "$clip_log")"
if [[ -e "$clip_file" ]]; then
  _fail "clip paste removes selected file"
else
  _pass "clip paste removes selected file"
fi

: >"$clip_file"
rm -f "$clip_log"
PATH="$clip_bin:$PATH" TMUX_TOOLS_TEST_TMUX_LOG="$clip_log" \
  tmux-clip-paste --file "$clip_file"
if [[ -e "$clip_log" ]]; then
  _fail "clip paste ignores empty selection"
else
  _pass "clip paste ignores empty selection"
fi
if [[ -e "$clip_file" ]]; then
  _fail "clip paste removes empty selection file"
else
  _pass "clip paste removes empty selection file"
fi

if command -v tmux >/dev/null 2>&1; then
  real_tmux=$(command -v tmux)
  socket_dir=$(_tmpdir)
  socket="$socket_dir/tmux-tools.sock"
  tool_bin=$(_tmpdir)
  session_dir=$(_tmpdir)
  project_dir=$(_tmpdir)
  stale_dir=$(_tmpdir)

  cat >"$tool_bin/tmux" <<MOCK
#!/usr/bin/env bash
exec "$real_tmux" -S "$socket" "\$@"
MOCK
  chmod +x "$tool_bin/tmux"

  "$real_tmux" -S "$socket" -f /dev/null new-session -d -s tmux-tools-test -n dup \
    -c "$project_dir" 'sleep 60'
  "$real_tmux" -S "$socket" new-window -t tmux-tools-test -n dup \
    -c "$stale_dir" 'sleep 60'
  second_window=$("$real_tmux" -S "$socket" display-message -p -t tmux-tools-test '#{window_index}')
  "$real_tmux" -S "$socket" split-window -t "tmux-tools-test:$second_window" \
    -c "$project_dir" 'sleep 60'
  "$real_tmux" -S "$socket" new-window -t tmux-tools-test -n stale \
    -c "$stale_dir" 'sleep 60'
  "$real_tmux" -S "$socket" select-window -t "tmux-tools-test:$second_window"

  PATH="$tool_bin:$PATH" TMUX_TOOLS_SESSION_DIR="$session_dir" \
    tmux-save-session tmux-tools-test >/dev/null

  rm -rf "$stale_dir"
  "$real_tmux" -S "$socket" kill-session -t tmux-tools-test

  PATH="$tool_bin:$PATH" TMUX_TOOLS_SESSION_DIR="$session_dir" \
    tmux-restore-session --no-attach tmux-tools-test >/dev/null

  active_panes=$("$real_tmux" -S "$socket" list-panes -t tmux-tools-test | wc -l | tr -d ' ')
  _assert_eq "restore preserves active saved window" "2" "$active_panes"

  mapfile -t restored_indexes < <("$real_tmux" -S "$socket" list-windows -t tmux-tools-test -F '#{window_index}')
  first_index="${restored_indexes[0]}"
  second_index="${restored_indexes[1]}"
  third_index="${restored_indexes[2]}"
  first_panes=$("$real_tmux" -S "$socket" list-panes -t "tmux-tools-test:$first_index" | wc -l | tr -d ' ')
  second_panes=$("$real_tmux" -S "$socket" list-panes -t "tmux-tools-test:$second_index" | wc -l | tr -d ' ')
  _assert_eq "restore handles duplicate first window name" "1" "$first_panes"
  _assert_eq "restore handles duplicate second window name" "2" "$second_panes"

  restored_dir=$("$real_tmux" -S "$socket" display-message -p -t "tmux-tools-test:$third_index.0" '#{pane_current_path}')
  _assert_eq "restore falls back to HOME for missing cwd" "$HOME" "$restored_dir"

  "$real_tmux" -S "$socket" kill-server
else
  printf 'skip - tmux server integration checks (tmux not installed)\n'
fi

if ((_failures > 0)); then
  printf '%s failure(s)\n' "$_failures" >&2
  exit 1
fi

printf 'all tests passed\n'
