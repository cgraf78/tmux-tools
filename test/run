#!/usr/bin/env bash

set -euo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

if command -v shellcheck >/dev/null 2>&1; then
  shellcheck -x -P "$ROOT" "$ROOT/bin/tmux-save-session" \
    "$ROOT/bin/tmux-restore-session" \
    "$ROOT/bin/tmux-clip-paste" \
    "$ROOT/lib/tmux-tools/session.sh" \
    "$ROOT/install.sh" \
    "$ROOT/test/tmux-tools-test" \
    "$ROOT/test/run"
fi

"$ROOT/test/tmux-tools-test"
