#!/usr/bin/env bash
# tmux-save-session -- save tmux session layout for later restoration.
#
# Captures window names, pane layouts, pane working directories, and the active
# window. Restore files are executable Bash scripts under the session save dir.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
if [[ -L "$_self" ]]; then
  _target="$(readlink "$_self")"
  [[ "$_target" == /* ]] || _target="$(cd "$(dirname "$_self")" && pwd)/$_target"
  _self="$_target"
fi
# shellcheck source=lib/tmux-tools/session.sh
. "$(cd "$(dirname "$_self")/.." && pwd)/lib/tmux-tools/session.sh"
unset _self _target

_usage() {
  cat <<'EOF'
Usage: tmux-save-session [--dir DIR] [session-name]

Save a tmux session layout for later restoration.

Arguments:
  session-name       Session to save. Defaults to the current tmux session.

Options:
  -d, --dir DIR      Directory for saved restore scripts.
                    Defaults to $TMUX_TOOLS_SESSION_DIR, then
                    an absolute $XDG_DATA_HOME/tmux/sessions, then
                    ~/.local/share/tmux/sessions.
  -h, --help         Show this help.
EOF
}

_die() {
  printf 'tmux-save-session: %s\n' "$*" >&2
  exit 2
}

_quote() {
  printf '%q' "$1"
}

_validate_session_name() {
  local session="$1"
  [[ -n "$session" ]] || _die "session name is empty"
  if [[ "$session" != "${session//[^A-Za-z0-9._-]/}" ]]; then
    _die "session name contains unsafe characters: $session"
  fi
}

save_dir=""
save_dir_set=0
session=""

while (($#)); do
  case "$1" in
    -d | --dir)
      shift
      (($#)) || _die "--dir requires a value"
      save_dir="$1"
      save_dir_set=1
      shift
      ;;
    --dir=*)
      save_dir="${1#--dir=}"
      [[ -n "$save_dir" ]] || _die "--dir requires a value"
      save_dir_set=1
      shift
      ;;
    -h | --help)
      _usage
      exit 0
      ;;
    --)
      shift
      (($# <= 1)) || _die "expected at most one session name"
      session="${1:-}"
      shift "$#"
      ;;
    -*)
      _die "unknown option: $1"
      ;;
    *)
      [[ -z "$session" ]] || _die "expected at most one session name"
      session="$1"
      shift
      ;;
  esac
done

if ((save_dir_set == 0)); then
  tmux_tools_resolve_session_dir ||
    _die "HOME is not set and XDG_DATA_HOME is not absolute"
  save_dir="$REPLY"
fi
[[ -n "$save_dir" ]] || _die "save directory is empty"

if [[ -z "$session" ]]; then
  session=$(tmux display-message -p '#S' 2>/dev/null) ||
    _die "not in a tmux session; pass a session name"
fi

_validate_session_name "$session"

if ! tmux has-session -t "$session" 2>/dev/null; then
  _die "no such tmux session: $session"
fi

old_umask=$(umask)
umask 077
mkdir -p "$save_dir"
umask "$old_umask"
outfile="$(tmux_tools_session_file "$save_dir" "$session")"
[[ ! -d "$outfile" ]] || _die "save destination is a directory: $outfile"
tmpfile=""
tmp_prefix="$save_dir/.${session}.sh.tmp.$$"
tmp_identity=""
redirected=""
pending_signal=0

_file_identity() {
  local path="$1" identity

  [[ "$path" != -* ]] || path="./$path"
  if identity=$(stat -L -c '%d:%i' "$path" 2>/dev/null); then
    :
  elif identity=$(stat -L -f '%d:%i' "$path" 2>/dev/null); then
    :
  else
    return 1
  fi
  REPLY="$identity"
}

_owns_temporary_path() {
  local path="$1"

  [[ -n "$tmp_identity" && -f "$path" && ! -L "$path" ]] || return 1
  _file_identity "$path" && [[ "$REPLY" == "$tmp_identity" ]]
}

_create_tmpfile() {
  local attempt old_umask had_noclobber=0

  [[ ! -o noclobber ]] || had_noclobber=1

  for ((attempt = 0; attempt < 100; attempt++)); do
    tmpfile="$tmp_prefix.$RANDOM.$RANDOM"
    old_umask=$(umask)
    umask 077
    set -o noclobber
    if { exec 3>"$tmpfile"; } 2>/dev/null; then
      ((had_noclobber)) || set +o noclobber
      umask "$old_umask"
      [[ -f "$tmpfile" && ! -L "$tmpfile" ]] ||
        _die "temporary save changed during creation: $tmpfile"
      _file_identity "$tmpfile" || _die "cannot identify temporary save: $tmpfile"
      tmp_identity="$REPLY"
      if ! _owns_temporary_path "$tmpfile"; then
        _die "temporary save changed during creation: $tmpfile"
      fi
      return 0
    fi
    ((had_noclobber)) || set +o noclobber
    umask "$old_umask"
  done
  tmpfile=""
  _die "cannot create an exclusive temporary save in: $save_dir"
}

# shellcheck disable=SC2317,SC2329 # Invoked indirectly by the EXIT trap.
_cleanup() {
  if [[ -n "$tmpfile" ]] && _owns_temporary_path "$tmpfile"; then
    rm -f -- "$tmpfile" || :
  fi
  if [[ -n "$redirected" ]] && _file_identity "$redirected" &&
    [[ -n "$tmp_identity" && "$REPLY" == "$tmp_identity" ]]; then
    rm -f -- "$redirected" || :
  fi
  exec 3>&- 2>/dev/null || :
}

# shellcheck disable=SC2317,SC2329 # Invoked indirectly by signal traps.
_record_signal() {
  pending_signal="$1"
}

trap _cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM
_create_tmpfile

active_window_index=$(tmux display-message -p -t "$session" '#{window_index}')

window_indexes=()
window_index_output=$(tmux list-windows -t "$session" -F '#{window_index}')
while IFS= read -r index; do
  window_indexes+=("$index")
done <<<"$window_index_output"

{
  printf '#!/usr/bin/env bash\n'
  printf 'set -euo pipefail\n'
  printf '# Saved: %s\n' "$(date -Iseconds)"
  printf '# Session: %s\n\n' "$session"
  printf 'SESSION=%s\n' "$(_quote "$session")"
  printf 'ACTIVE_WINDOW_INDEX=%s\n\n' "$(_quote "$active_window_index")"
  cat <<'EOF'
_existing_dir() {
  local dir="$1"
  if [[ -d "$dir" ]]; then
    printf '%s\n' "$dir"
  else
    printf '%s\n' "${HOME:-/}"
  fi
}

_new_session_window() {
  local name="$1"
  local dir
  dir=$(_existing_dir "$2")
  tmux new-session -d -P -F '#{window_id}' -s "$SESSION" -n "$name" -c "$dir"
}

_new_window() {
  local name="$1"
  local dir
  dir=$(_existing_dir "$2")
  tmux new-window -P -F '#{window_id}' -t "$SESSION" -n "$name" -c "$dir"
}

_split_window() {
  local target="$1"
  local dir
  dir=$(_existing_dir "$2")
  tmux split-window -t "$target" -c "$dir"
}

if tmux has-session -t "$SESSION" 2>/dev/null; then
  printf 'tmux session already exists: %s\n' "$SESSION" >&2
  exit 1
fi

window_ids=()
window_indexes=()

EOF

  for i in "${!window_indexes[@]}"; do
    widx="${window_indexes[$i]}"
    wlayout=$(tmux display-message -p -t "$session:$widx" '#{window_layout}')
    wname=$(tmux display-message -p -t "$session:$widx" '#{window_name}')

    pane_dirs=()
    pane_dir_output=$(tmux list-panes -t "$session:$widx" -F '#{pane_current_path}')
    while IFS= read -r pdir; do
      pane_dirs+=("$pdir")
    done <<<"$pane_dir_output"

    printf 'window_indexes+=(%s)\n' "$(_quote "$widx")"
    if ((i == 0)); then
      # shellcheck disable=SC2016 # emitted into the generated restore script.
      printf 'window_id=$(_new_session_window %s %s)\n' \
        "$(_quote "$wname")" "$(_quote "${pane_dirs[0]:-$HOME}")"
    else
      # shellcheck disable=SC2016 # emitted into the generated restore script.
      printf 'window_id=$(_new_window %s %s)\n' \
        "$(_quote "$wname")" "$(_quote "${pane_dirs[0]:-$HOME}")"
    fi
    # shellcheck disable=SC2016 # emitted into the generated restore script.
    printf 'window_ids+=("$window_id")\n'

    for ((p = 1; p < ${#pane_dirs[@]}; p++)); do
      # shellcheck disable=SC2016 # emitted into the generated restore script.
      printf '_split_window "$window_id" %s\n' "$(_quote "${pane_dirs[$p]}")"
    done

    if ((${#pane_dirs[@]} > 1)); then
      # shellcheck disable=SC2016 # emitted into the generated restore script.
      printf 'tmux select-layout -t "$window_id" %s\n' "$(_quote "$wlayout")"
    fi

    printf '\n'
  done

  cat <<'EOF'
for i in "${!window_indexes[@]}"; do
  if [[ "${window_indexes[$i]}" == "$ACTIVE_WINDOW_INDEX" ]]; then
    tmux select-window -t "${window_ids[$i]}"
    break
  fi
done
EOF
} >&3

bash -n "$tmpfile"
_owns_temporary_path "$tmpfile" ||
  _die "temporary save changed before publication: $tmpfile"
chmod 700 "$tmpfile" || _die "cannot secure temporary save: $tmpfile"
if ! _owns_temporary_path "$tmpfile"; then
  _die "temporary save changed before publication: $tmpfile"
fi
redirected="$outfile/${tmpfile##*/}"
# A signal delivered while Bash waits for mv runs its trap before the next
# command. Defer that signal until the installed inode tells us whether the
# atomic replacement committed.
trap '_record_signal 129' HUP
trap '_record_signal 130' INT
trap '_record_signal 143' TERM
mv_status=0
mv -- "$tmpfile" "$outfile" || mv_status=$?
redirected_owned=0
if _file_identity "$redirected" && [[ "$REPLY" == "$tmp_identity" ]]; then
  redirected_owned=1
fi
if ((redirected_owned == 0)) && {
  ((mv_status == 0)) || [[ ! -e "$tmpfile" && ! -L "$tmpfile" ]]
}; then
  tmpfile=""
  redirected=""
  exec 3>&- 2>/dev/null || :
  # The rename is the commit point. Nothing after it may report failure while
  # leaving the new save installed.
  trap '' HUP INT TERM
  trap - EXIT
  printf 'saved: %s\n' "$outfile" || :
  exit 0
else
  if ((redirected_owned)); then
    rm -f -- "$redirected" || :
  fi
  if ((pending_signal)); then
    exit "$pending_signal"
  fi
  if ((mv_status)); then
    _die "cannot publish save: $outfile"
  fi
  _die "save destination changed during publication: $outfile"
fi
